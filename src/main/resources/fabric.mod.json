{
	"schemaVersion": 1,
	"id": "betterbackups",
	"version": "${version}",
	"name": "betterbackups",
	"description": "a mod to view your created backups without need to open the explorer",
	"authors": [
		"shadowdara"
	],
	"contact": {
		"homepage": "https://modrinth.com/mod/betterbackups",
		"sources": "https://github.com/shadowdara/betterbackups"
	},
	"license": "MIT",
	"icon": "assets/betterbackups/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"de.shadowdara.betterbackups.Betterbackups"
		],
		"fabric-datagen": [
			"de.shadowdara.betterbackups.BetterbackupsDataGenerator"
		],
        "client":  [
          "de.shadowdara.betterbackups.BetterbackupsClient"
        ]
	},
	"mixins": [
		"betterbackups.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.17.2",
		"minecraft": "~1.20.1",
		"java": ">=17",
		"fabric-api": "*"
	},
	"suggests": {
		"another-mod": "*"
	}
}